{
  "name": "@fgp/proxy",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno serve --watch --allow-net --allow-env --allow-read src/main.ts",
    "start": "deno serve --allow-net --allow-env --allow-read src/main.ts",
    "test": "deno test --allow-net --allow-env --allow-read tests/",
    "test:unit": "deno test --allow-env --allow-read tests/testu/",
    "test:integration": "deno test --allow-net --allow-env --allow-read tests/testi/",
    "test:e2e": "deno test --allow-net --allow-env --allow-read tests/teste2e/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/**/*.ts src/**/*.tsx tests/**/*.ts",
    "verify": "deno task lint && deno task fmt:check && deno task check && deno task test"
  },
  "imports": {
    "hono": "npm:hono@^4",
    "@hono/swagger-ui": "npm:@hono/swagger-ui@^0.6",
    "zod": "npm:zod@^3.24",
    "@hono/zod-openapi": "npm:@hono/zod-openapi@^0.19",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/testing": "jsr:@std/testing@^1",
    "@std/encoding": "jsr:@std/encoding@^1",
    "@std/crypto": "jsr:@std/crypto@^1"
  },
  "compilerOptions": {
    "strict": true,
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": ["docs/", "*.md"]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve",
    "exclude": ["docs/", "*.md"]
  },
  "exclude": [".claude/", "node_modules/"]
}
