{
  "name": "@fgp/proxy",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "build:client": "deno run -A npm:esbuild src/ui/client.ts --bundle --outfile=static/client.js --format=iife --minify --target=es2020",
    "dev:client": "deno run -A npm:esbuild src/ui/client.ts --bundle --outfile=static/client.js --format=iife --watch",
    "dev:server": "deno serve --watch --allow-net --allow-env --allow-read src/main.ts",
    "dev": "deno run -A npm:concurrently --names client,server --prefix-colors blue,green 'deno task dev:client' 'deno task dev:server'",
    "start": "deno task build:client && deno serve --allow-net --allow-env --allow-read src/main.ts",
    "deploy": "deno task build:client && deployctl deploy --project=fgp-proxy --entrypoint=src/main.ts --include=src,static,deno.json,deno.lock",
    "test": "deno test --allow-net --allow-env --allow-read tests/",
    "test:unit": "deno test --allow-env --allow-read tests/testu/",
    "test:integration": "deno test --allow-net --allow-env --allow-read tests/testi/",
    "test:e2e": "deno test --allow-net --allow-env --allow-read tests/teste2e/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/main.ts src/middleware/*.ts src/crypto/*.ts src/auth/*.ts src/routes/*.tsx tests/**/*.ts",
    "verify": "deno task lint && deno task fmt:check && deno task check && deno task test"
  },
  "imports": {
    "hono": "npm:hono@^4",
    "@hono/swagger-ui": "npm:@hono/swagger-ui@^0.6",
    "zod": "npm:zod@^4",
    "@hono/zod-openapi": "npm:@hono/zod-openapi@^1.2",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/testing": "jsr:@std/testing@^1",
    "@std/encoding": "jsr:@std/encoding@^1",
    "@std/crypto": "jsr:@std/crypto@^1"
  },
  "compilerOptions": {
    "strict": true,
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": ["docs/", "*.md", "static/", "src/ui/client.ts"]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve",
    "exclude": ["docs/", "*.md", "static/"]
  },
  "exclude": [".claude/", "node_modules/", "static/"],
  "deploy": {
    "org": "lsagetlethias",
    "app": "fgp-proxy"
  }
}
